# فایل تنظیمات محیطی
# این فایل را کپی کرده و نام آن را به .env تغییر دهید
# سپس API Key های خود را اضافه کنید

# Gemini API Key
# برای دریافت API Key به https://makersuite.google.com/app/apikey مراجعه کنید
GEMINI_API_KEY=your_gemini_api_key_here

# تنظیمات اضافی (اختیاری)
# GEMINI_MODEL=gemini-2.0-flash-exp
# LOG_LEVEL=INFO
# DEBUG_MODE=false